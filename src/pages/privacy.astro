---
import Layout from "../layouts/Layout.astro";
import "./../styles/global.css"; 
---

<Layout title="Privacy Policy">
  <!-- Background Blur Effects -->
  <div class="bg-[#2563eb]/40 w-[240px] h-[250px] absolute top-0 right-0 -translate-x-1/2 blur-[160px] z-0" />
  <div class="bg-[#2563eb]/30 w-[240px] h-[250px] absolute top-0 left-0 -translate-x-1/2 blur-[160px] z-0" />
  <div class="bg-white/10 w-[50px] h-[50px] absolute top-0 left-0 -translate-x-1/2 blur-[160px] z-0" />

  <!-- Content Wrapper -->
  <div class="relative z-10 max-w-3xl mx-auto px-6 py-20 text-gray-200">
    <h1 class="text-4xl font-bold mb-6 text-blue-400">Privacy Policy</h1>
    <p class="mb-8 text-lg text-gray-300">
      Welcome to our website! Your privacy is important to us. This policy explains how we collect, use, and protect your personal data.
    </p>

    <section class="mb-8">
      <h2 class="text-2xl font-semibold mb-2 text-gray-100">1. Information Collection</h2>
      <p class="text-gray-300">We collect information you provide directly (e.g. account creation or contact forms), as well as automatically collected data such as your IP address and browser type.</p>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-semibold mb-2 text-gray-100">2. Use of Information</h2>
      <p class="text-gray-300">Your data helps us deliver and improve our services, respond to your inquiries, and meet legal requirements.</p>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-semibold mb-2 text-gray-100">3. Data Sharing</h2>
      <p class="text-gray-300">We do not sell or rent your data. We may share it with trusted partners who assist in operating our services, under strict confidentiality obligations.</p>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-semibold mb-2 text-gray-100">4. Data Security</h2>
      <p class="text-gray-300">We use reasonable security measures to protect your information. However, no online transmission or storage system is completely secure.</p>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-semibold mb-2 text-gray-100">5. Your Rights</h2>
      <p class="text-gray-300">You can access, update, or delete your personal data, and restrict or object to its processing. Contact us to exercise these rights.</p>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-semibold mb-2 text-gray-100">6. Changes to This Policy</h2>
      <p class="text-gray-300">We may revise this policy occasionally. Updates will be posted here. Continued use of our site means you accept the new terms.</p>
    </section>

    <section>
      <h2 class="text-2xl font-semibold mb-2 text-gray-100">7. Contact Us</h2>
      <p class="text-gray-300">If you have questions or concerns, reach out to us at <a href="mailto:your@email.com" class="text-blue-400 underline">your@email.com</a>.</p>
    </section>
  </div>
</Layout>
